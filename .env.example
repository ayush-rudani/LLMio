# 1--- section: setup inside your `.env.local` file (auto-generated by convex dev)
# These are added automatically by `npx convex dev`, but you need to add VITE_CONVEX_SITE_URL and VITE_SITE_URL
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site
VITE_SITE_URL=http://localhost:3000
VITE_CONVEX_API_URL=http://127.0.0.1:3210/http
VITE_POSTHOG_HOST=https://eu.i.posthog.com
VITE_POSTHOG_KEY=phc_***
# 1---


# 2--- section: Add these in convex dashboard (Environment Variables)
# Authentication
BETTER_AUTH_SECRET="<npx convex env set BETTER_AUTH_SECRET=$(openssl rand -base64 32)>"
SITE_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# URLs (for CORS)
LOCAL_URL=http://localhost:3000
VERCEL_URL=
PROD_URL=

# Redis for caching
UPSTASH_REDIS_REST_URL="<upstash instance, NOT local redis>"
UPSTASH_REDIS_REST_TOKEN="<upstash key>"

# Encryption
ENCRYPTION_KEY="<bunx uuid>"

# AI API Keys
OPENAI_API_KEY="sk-meow-****"
GOOGLE_GENERATIVE_AI_API_KEY="AI***"

# R2 Storage
R2_FORCE_PATH_STYLE=true
R2_BUCKET=intern3-user-files
R2_ENDPOINT="http://localhost:9000"
R2_ACCESS_KEY_ID="minioadmin"
R2_SECRET_ACCESS_KEY="minioadmin"

# Email Configuration (for OTP emails)
EMAIL_PROVIDER=<resend|local-only-mock>
EMAIL_FROM=noreply@yourdomain.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# 2--- end section


# IMPORTANT: Google OAuth Redirect URI
# After migration, update your Google Cloud Console OAuth settings:
# Add redirect URI: https://your-deployment.convex.site/api/auth/callback/google
# (Replace your-deployment with your actual Convex deployment name)

# Note: `.env.local` is generated by convex. The VITE_* variables are read by Vite.
# Convex environment variables are set via `npx convex env set KEY=value`